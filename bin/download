#!/usr/bin/env bash

set -euo pipefail

current_script_path=${BASH_SOURCE[0]}
plugin_dir=$(dirname "$(dirname "$current_script_path")")

# shellcheck source=./lib/utils.bash
source "${plugin_dir}/lib/utils.bash"

mkdir -p "$ASDF_DOWNLOAD_PATH"

release_file="$ASDF_DOWNLOAD_PATH/$TOOL_NAME-$ASDF_INSTALL_VERSION"

arch=$(uname -m)

if [[ "$OSTYPE" == "linux-gnu"* ]]; then
	if [[ "$arch" == "x86_64" ]]; then
		target="x86_64-unknown-linux-musl"
	elif [[ "$arch" == "aarch64" ]]; then
		target="aarch64-unknown-linux-musl"
	else
		fail "Unsupported architecture"
	fi
elif [[ "$OSTYPE" == "darwin"* ]]; then
	if [[ "$arch" == "x86_64" ]]; then
		target="x86_64-apple-darwin"
	elif [[ "$arch" == "arm64" ]]; then
		target="aarch64-apple-darwin"
	else
		fail "Unsupported architecture"
	fi
else
	fail "Unsupported platform"
fi

# Download file to the download directory
download_release "$ASDF_INSTALL_VERSION" "$target" "$release_file"

#  Move file into the download directory
mv "$release_file" "$ASDF_DOWNLOAD_PATH/$TOOL_NAME" || fail "Could not move $release_file to $ASDF_DOWNLOAD_PATH"
chmod +x "$ASDF_DOWNLOAD_PATH/$TOOL_NAME" || fail "Could not make $ASDF_DOWNLOAD_PATH/$TOOL_NAME executable"
